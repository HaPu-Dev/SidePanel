-- ================= TELEPORT FUNCTION =================
local lastTeleport = ""
local teleportCooldown = false

local function teleportTo(x, y, z, showMessage)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(x, y, z)
        if showMessage ~= false then
            statusLabel.Text = string.format("✓ Teleported to (%.1f, %.1f, %.1f)", x, y, z)
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            task.wait(2)
            if statusLabel.Text:match("✓") then
                statusLabel.Text = ""
            end
        end
    else
        statusLabel.Text = "❌ Character not found!"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        task.wait(2)
        statusLabel.Text = ""
    end
end

-- ================= PARSE COORDINATES =================
local function parseCoordinates(input)
    -- Remove spaces and split by commas
    local cleaned = input:gsub("%s+", "")
    local parts = {}
    for part in cleaned:gmatch("([^,]+)") do
        table.insert(parts, tonumber(part))
    end
    
    if #parts == 3 then
        local x, y, z = parts[1], parts[2], parts[3]
        if x and y and z then
            return x, y, z
        end
    end
    return nil, nil, nil
end

-- Auto-teleport when text changes
local debounce = false
coordBox:GetPropertyChangedSignal("Text"):Connect(function()
    local input = coordBox.Text
    if input == "" or debounce then
        return
    end
    
    debounce = true
    task.wait(0.1) -- Small delay to prevent spam
    debounce = false
    
    -- Only auto-teleport if we have new input
    if input ~= "" then
        local x, y, z = parseCoordinates(input)
        if x and y and z then
            -- Check if it's different from last teleport to avoid duplicate teleports
            local coordString = string.format("%.1f,%.1f,%.1f", x, y, z)
            if coordString ~= lastTeleport then
                lastTeleport = coordString
                teleportTo(x, y, z, true)
                -- Optional: Clear the textbox after teleport (uncomment if desired)
                -- coordBox.Text = ""
            end
        end
    end
end)

