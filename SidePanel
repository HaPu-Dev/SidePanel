    local btnStroke = Instance.new("UIStroke")  
    btnStroke.Thickness = 1.2  
    btnStroke.Transparency = 0.4  
    btnStroke.Color = Color3.fromRGB(128, 0, 255)  
    btnStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border  
    btnStroke.Parent = btn  
    
