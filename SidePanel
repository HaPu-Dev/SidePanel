        btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)  
        btnStroke.Transparency = 0.4  
        btnStroke.Thickness = 1.2  
    end)  
    
    btn.MouseButton1Click:Connect(function()  
        teleportTo(x, y, z)  
    end)  
    
    return btn
end

